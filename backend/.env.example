# =============================================================================
# VoiceLink — Environment Variables
# Copy to .env and fill in values. Never commit .env to source control.
# =============================================================================

# --- Server ---
PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/voicelink

# --- Redis ---
REDIS_URL=redis://localhost:6381

# --- JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# --- Active Telephony Provider (twilio | vonage | bandwidth | plivo | telnyx) ---
TELEPHONY_PROVIDER=twilio

# --- Twilio (active in v1) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# --- Vonage (stub in v1 — populate to activate) ---
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_APPLICATION_ID=
VONAGE_PRIVATE_KEY=

# --- Bandwidth (stub in v1) ---
BANDWIDTH_USERNAME=
BANDWIDTH_PASSWORD=
BANDWIDTH_ACCOUNT_ID=
BANDWIDTH_APPLICATION_ID=

# --- Plivo (stub in v1) ---
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# --- Telnyx (stub in v1) ---
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- SendGrid (email) ---
SENDGRID_API_KEY=

# --- AWS S3 / Cloudflare R2 (media storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
S3_ENDPOINT=

# --- OpenAI (Whisper STT fallback) ---
OPENAI_API_KEY=

# --- Go Dialer Service ---
DIALER_SERVICE_URL=http://localhost:8080
INTERNAL_API_KEY=change-me-internal-key
