// VoiceLink — Prisma Schema
// Database: PostgreSQL 15+
// Derived from: database-schema.md, SDD §5.2, PAL §7

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// 1. users — Core user accounts
// =============================================================================
model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique @db.VarChar(255)
  passwordHash       String?   @map("password_hash") @db.VarChar(255)
  emailVerified      Boolean   @default(false) @map("email_verified")
  totpSecret         String?   @map("totp_secret") @db.VarChar(255)
  totpEnabled        Boolean   @default(false) @map("totp_enabled")
  googleId           String?   @unique @map("google_id") @db.VarChar(255)
  phone              String?   @unique @db.VarChar(20)
  firstName          String?   @map("first_name") @db.VarChar(100)
  lastName           String?   @map("last_name") @db.VarChar(100)
  avatarUrl          String?   @map("avatar_url") @db.Text
  role               String    @default("user") @db.VarChar(20) // user | business | admin
  stripeCustomerId   String?   @map("stripe_customer_id") @db.VarChar(100)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  plan              Plan?             @relation(fields: [planId], references: [id])
  planId            String?           @map("plan_id") @db.Uuid
  phoneNumbers      PhoneNumber[]
  conversations     Conversation[]
  calls             Call[]
  voicemails        Voicemail[]
  contacts          Contact[]
  campaigns         Campaign[]
  subscriptions     Subscription[]
  usageRecords      UsageRecord[]
  invoices          Invoice[]
  refreshTokens     RefreshToken[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  messageTemplates  MessageTemplate[]
  dncEntries        DncEntry[]

  @@map("users")
}

// =============================================================================
// 2. phone_numbers — Virtual DID numbers provisioned through PAL
// =============================================================================
model PhoneNumber {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  number       String   @db.VarChar(20)
  providerSid  String   @map("provider_sid") @db.VarChar(50)
  provider     String   @default("twilio") @db.VarChar(20) // twilio | vonage | bandwidth | plivo | telnyx
  friendlyName String?  @map("friendly_name") @db.VarChar(100)
  countryCode  String   @map("country_code") @db.Char(2)
  capabilities Json     @db.JsonB // {voice: bool, sms: bool, mms: bool}
  status       String   @default("active") @db.VarChar(20) // active | releasing | released
  monthlyCost  Decimal? @map("monthly_cost") @db.Decimal(8, 4)
  releasedAt   DateTime? @map("released_at") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_phone_numbers_user")
  @@index([number], map: "idx_phone_numbers_number")
  @@index([provider], map: "idx_phone_numbers_provider")
  @@map("phone_numbers")
}

// =============================================================================
// 3. conversations — Message threads between a user's DID and an external number
// =============================================================================
model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  fromNumber    String    @map("from_number") @db.VarChar(20)
  toNumber      String    @map("to_number") @db.VarChar(20)
  contactName   String?   @map("contact_name") @db.VarChar(255)
  unreadCount   Int       @default(0) @map("unread_count")
  lastMessageAt DateTime? @map("last_message_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userId, fromNumber, toNumber])
  @@index([userId, lastMessageAt(sort: Desc)], map: "idx_conversations_user")
  @@map("conversations")
}

// =============================================================================
// 4. messages — Individual SMS/MMS messages
// =============================================================================
model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  providerSid    String?   @map("provider_sid") @db.VarChar(50)
  provider       String    @default("twilio") @db.VarChar(20)
  direction      String    @db.VarChar(10) // inbound | outbound
  body           String?   @db.Text
  mediaUrls      String[]  @map("media_urls") @db.Text
  status         String    @db.VarChar(20) // queued | sent | delivered | failed
  errorCode      String?   @map("error_code") @db.VarChar(20)
  segments       Int       @default(1)
  scheduledAt    DateTime? @map("scheduled_at") @db.Timestamptz()
  readAt         DateTime? @map("read_at") @db.Timestamptz()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)], map: "idx_messages_conversation")
  @@index([createdAt(sort: Desc)], map: "idx_messages_created")
  @@index([providerSid], map: "idx_messages_provider_sid")
  @@index([status], map: "idx_messages_status")
  @@map("messages")
}

// =============================================================================
// 5. calls — Call Detail Records (CDRs)
// =============================================================================
model Call {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String?   @map("user_id") @db.Uuid
  providerCallSid          String?   @unique @map("provider_call_sid") @db.VarChar(50)
  provider                 String    @default("twilio") @db.VarChar(20)
  fromNumber               String    @map("from_number") @db.VarChar(20)
  toNumber                 String    @map("to_number") @db.VarChar(20)
  direction                String    @db.VarChar(10) // inbound | outbound
  status                   String    @db.VarChar(20) // initiated | ringing | in-progress | completed | failed | busy | no-answer
  durationSeconds          Int       @default(0) @map("duration_seconds")
  recordingUrl             String?   @map("recording_url") @db.Text
  recordingDuration        Int?      @map("recording_duration")
  recordingDisclosurePlayed Boolean  @default(false) @map("recording_disclosure_played")
  cost                     Decimal?  @db.Decimal(10, 6)
  startedAt                DateTime? @map("started_at") @db.Timestamptz()
  endedAt                  DateTime? @map("ended_at") @db.Timestamptz()
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  voicemails Voicemail[]

  @@index([userId, createdAt(sort: Desc)], map: "idx_calls_user_created")
  @@index([status], map: "idx_calls_status")
  @@index([providerCallSid], map: "idx_calls_provider_sid")
  @@map("calls")
}

// =============================================================================
// 6. voicemails — Recordings and transcripts for missed calls
// =============================================================================
model Voicemail {
  id                  String   @id @default(uuid()) @db.Uuid
  callId              String?  @map("call_id") @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  fromNumber          String   @map("from_number") @db.VarChar(20)
  recordingUrl        String   @map("recording_url") @db.Text
  transcript          String?  @db.Text
  transcriptionSource String?  @map("transcription_source") @db.VarChar(20) // provider | external-stt
  durationSeconds     Int?     @map("duration_seconds")
  isRead              Boolean  @default(false) @map("is_read")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  call Call? @relation(fields: [callId], references: [id])
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voicemails")
}

// =============================================================================
// 7. contacts — User address book entries
// =============================================================================
model Contact {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  notes     String?  @db.Text
  tags      String[] @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  phones ContactPhone[]

  @@map("contacts")
}

// =============================================================================
// 8. contact_phones — Phone numbers for a contact
// =============================================================================
model ContactPhone {
  id        String @id @default(uuid()) @db.Uuid
  contactId String @map("contact_id") @db.Uuid
  number    String @db.VarChar(20) // E.164
  label     String? @db.VarChar(50) // mobile | work | home | other

  // Relations
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("contact_phones")
}

// =============================================================================
// 9. campaigns — Power dialer campaign definitions
// =============================================================================
model Campaign {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  name               String    @db.VarChar(255)
  status             String    @default("draft") @db.VarChar(20) // draft | running | paused | completed | stopped
  fromNumber         String    @map("from_number") @db.VarChar(20)
  concurrency        Int       @default(1) // 1–10 simultaneous calls
  delaySeconds       Int       @default(0) @map("delay_seconds") // 0–60
  retryMax           Int       @default(0) @map("retry_max") // 0–3
  voicemailDropUrl   String?   @map("voicemail_drop_url") @db.Text
  callingHoursStart  String?   @map("calling_hours_start") @db.VarChar(5) // e.g. 09:00
  callingHoursEnd    String?   @map("calling_hours_end") @db.VarChar(5) // e.g. 17:00
  callingHoursTimezone String? @map("calling_hours_timezone") @db.VarChar(50) // IANA
  totalContacts      Int       @default(0) @map("total_contacts")
  dialed             Int       @default(0)
  answered           Int       @default(0)
  failed             Int       @default(0)
  busy               Int       @default(0)
  noAnswer           Int       @default(0) @map("no_answer")
  scheduledAt        DateTime? @map("scheduled_at") @db.Timestamptz()
  startedAt          DateTime? @map("started_at") @db.Timestamptz()
  pausedAt           DateTime? @map("paused_at") @db.Timestamptz()
  completedAt        DateTime? @map("completed_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts CampaignContact[]

  @@index([userId, createdAt(sort: Desc)], map: "idx_campaigns_user")
  @@index([status], map: "idx_campaigns_status")
  @@map("campaigns")
}

// =============================================================================
// 10. campaign_contacts — Individual contacts within a dialer campaign
// =============================================================================
model CampaignContact {
  id               String    @id @default(uuid()) @db.Uuid
  campaignId       String    @map("campaign_id") @db.Uuid
  phone            String    @db.VarChar(20) // E.164
  name             String?   @db.VarChar(255)
  notes            String?   @db.Text
  status           String    @default("pending") @db.VarChar(20) // pending | dialing | answered | no-answer | busy | failed | dnc
  attempts         Int       @default(0)
  callDuration     Int?      @map("call_duration")
  lastAttemptedAt  DateTime? @map("last_attempted_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status], map: "idx_campaign_contacts_campaign")
  @@index([phone], map: "idx_campaign_contacts_phone")
  @@map("campaign_contacts")
}

// =============================================================================
// 11. plans — Subscription plan definitions
// =============================================================================
model Plan {
  id                           String  @id @default(uuid()) @db.Uuid
  name                         String  @db.VarChar(50) // Free | Pro | Business
  stripePriceId                String? @map("stripe_price_id") @db.VarChar(100)
  maxNumbers                   Int     @default(1) @map("max_numbers")
  includedMinutes              Int     @default(0) @map("included_minutes")
  includedSms                  Int     @default(0) @map("included_sms")
  includedMms                  Int     @default(0) @map("included_mms")
  powerDialerEnabled           Boolean @default(false) @map("power_dialer_enabled")
  callRecordingEnabled         Boolean @default(false) @map("call_recording_enabled")
  voicemailTranscriptionEnabled Boolean @default(false) @map("voicemail_transcription_enabled")
  maxConcurrency               Int     @default(1) @map("max_concurrency")
  monthlyPrice                 Decimal @default(0) @map("monthly_price") @db.Decimal(8, 2)
  createdAt                    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  users         User[]
  subscriptions Subscription[]

  @@map("plans")
}

// =============================================================================
// 12. subscriptions — Links user to plan, tracks Stripe state
// =============================================================================
model Subscription {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @map("user_id") @db.Uuid
  planId               String    @map("plan_id") @db.Uuid
  stripeSubscriptionId String?   @map("stripe_subscription_id") @db.VarChar(100)
  status               String    @default("active") @db.VarChar(20) // active | canceled | past_due | trialing
  currentPeriodStart   DateTime? @map("current_period_start") @db.Timestamptz()
  currentPeriodEnd     DateTime? @map("current_period_end") @db.Timestamptz()
  canceledAt           DateTime? @map("canceled_at") @db.Timestamptz()
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// =============================================================================
// 13. usage_records — Per-user monthly usage tracking
// =============================================================================
model UsageRecord {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @map("user_id") @db.Uuid
  periodStart            DateTime @map("period_start") @db.Date
  periodEnd              DateTime @map("period_end") @db.Date
  minutesUsed            Int      @default(0) @map("minutes_used")
  smsSent                Int      @default(0) @map("sms_sent")
  smsReceived            Int      @default(0) @map("sms_received")
  mmsSent                Int      @default(0) @map("mms_sent")
  mmsReceived            Int      @default(0) @map("mms_received")
  numbersHeld            Int      @default(0) @map("numbers_held")
  prepaidCreditsRemaining Decimal? @default(0) @map("prepaid_credits_remaining") @db.Decimal(10, 4)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId, periodStart(sort: Desc)], map: "idx_usage_records_user_period")
  @@map("usage_records")
}

// =============================================================================
// 14. invoices — Monthly billing invoices
// =============================================================================
model Invoice {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  stripeInvoiceId    String?   @map("stripe_invoice_id") @db.VarChar(100)
  stripeInvoiceNumber String?  @map("stripe_invoice_number") @db.VarChar(50)
  amount             Decimal   @db.Decimal(10, 2)
  currency           String    @default("USD") @db.Char(3)
  status             String    @db.VarChar(20) // draft | open | paid | void | uncollectible
  periodStart        DateTime  @map("period_start") @db.Date
  periodEnd          DateTime  @map("period_end") @db.Date
  pdfUrl             String?   @map("pdf_url") @db.Text
  paidAt             DateTime? @map("paid_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_invoices_user")
  @@map("invoices")
}

// =============================================================================
// 15. refresh_tokens — Active refresh tokens for JWT session management
// =============================================================================
model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  family     String    @db.VarChar(255)
  deviceInfo String?   @map("device_info") @db.VarChar(255)
  ipAddress  String?   @map("ip_address") @db.Inet
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_refresh_tokens_user")
  @@index([family], map: "idx_refresh_tokens_family")
  @@index([expiresAt], map: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}

// =============================================================================
// 16. api_keys — Programmatic access keys for API users
// =============================================================================
model ApiKey {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String    @db.VarChar(100)
  keyPrefix  String    @map("key_prefix") @db.VarChar(12) // first 8 chars, plaintext
  keyHash    String    @map("key_hash") @db.VarChar(255) // bcrypt hash
  scopes     String[]  @db.Text // e.g. {sms:send,calls:read}
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz()
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_api_keys_user")
  @@map("api_keys")
}

// =============================================================================
// 17. audit_logs — Immutable audit trail
// =============================================================================
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String   @db.VarChar(100) // e.g. user.created, number.provisioned
  resourceType String?  @map("resource_type") @db.VarChar(50)
  resourceId   String?  @map("resource_id") @db.Uuid
  details      Json?    @db.JsonB
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)], map: "idx_audit_logs_user")
  @@index([action, createdAt(sort: Desc)], map: "idx_audit_logs_action")
  @@index([resourceType, resourceId], map: "idx_audit_logs_resource")
  @@map("audit_logs")
}

// =============================================================================
// 18. email_verification_tokens — One-time tokens for account verification
// =============================================================================
model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @db.VarChar(255)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([email], map: "idx_email_verify_email")
  @@map("email_verification_tokens")
}

// =============================================================================
// 19. password_reset_tokens — One-time tokens for password reset
// =============================================================================
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @db.VarChar(255)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz() // typically 1 hour
  usedAt    DateTime? @map("used_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([email], map: "idx_password_reset_email")
  @@map("password_reset_tokens")
}

// =============================================================================
// 20. otp_codes — Short-lived SMS OTP codes for phone login
// =============================================================================
model OtpCode {
  id          String    @id @default(uuid()) @db.Uuid
  phone       String    @db.VarChar(20) // E.164
  codeHash    String    @map("code_hash") @db.VarChar(255) // bcrypt hash of 6-digit code
  action      String    @db.VarChar(20) // login | verify_phone
  attempts    Int       @default(0)
  maxAttempts Int       @default(5) @map("max_attempts")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz() // typically 5 minutes
  usedAt      DateTime? @map("used_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([phone, action, createdAt(sort: Desc)], map: "idx_otp_phone_action")
  @@map("otp_codes")
}

// =============================================================================
// 21. message_templates — Reusable SMS templates for business users
// =============================================================================
model MessageTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  body      String   @db.Text
  variables String[] @db.Text // e.g. {customer_name}, {order_number}
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_message_templates_user")
  @@map("message_templates")
}

// =============================================================================
// 22. dnc_list — Do-Not-Call list
// =============================================================================
model DncEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  phone     String   @db.VarChar(20) // E.164
  source    String   @db.VarChar(50) // manual | csv_import | campaign_opt_out | system_tcpa
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId], map: "idx_dnc_user")
  @@index([phone], map: "idx_dnc_phone")
  @@map("dnc_list")
}
